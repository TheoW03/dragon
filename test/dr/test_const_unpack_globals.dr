"""Module-level const unpack targets are real module globals.

Given the code below:

    const HOST: str, PORT: int = ("h" + str(1), 8080)

    def reader() -> str {
        return HOST                     # was: "Undefined variable: HOST"
    }

The type checker registered HOST/PORT in module scope and accepted the
cross-function reference, but codegen lowered the unpack targets as
main-frame LOCALS - so the very programs the checker passed failed to
compile. A checker/codegen disagreement: the program was either legal or
not, and the two halves voted differently.

BEFORE: any function referencing a module-level unpack target failed
codegen. AFTER: module-level unpack targets lower as GlobalVariables
(same as annotated declarations), with the D018 marking applied - const
str targets promoted immortal, containers/instances SHARED-marked - and
the forward-declaration pre-pass registers them from the checker-resolved
element types, so CLASS METHODS (whose bodies compile before the module
body) resolve them too - this suite's methods below are that regression

One line: what the checker admits, codegen now lowers 
"""

from unittest import TestCase, main


const HOST: str, PORT: int = ("h" + str(1), 8080)
const LO: int, HI: int = (10, 99)


def read_host() -> str {
    return HOST
}


def read_span() -> int {
    return HI - LO
}


class ConstUnpackGlobalTests(TestCase) {
    def test_unpack_targets_visible_at_module_level() {
        self.assertEqual(HOST, "h1")
        self.assertEqual(PORT, 8080)
        self.assertEqual(LO, 10)
        self.assertEqual(HI, 99)
    }

    def test_unpack_targets_readable_from_functions() {
        self.assertEqual(read_host(), "h1")
        self.assertEqual(read_span(), 89)
    }

    def test_repeated_reads_of_unpacked_str_global() {
        # The const str target is immortal-promoted at store; copies must
        # stay intact across many reads
        i: int = 0
        while i < 2000 {
            const v: str = HOST
            self.assertEqual(len(v), 2)
            i = i + 1
        }
    }
}


main([ConstUnpackGlobalTests()])
