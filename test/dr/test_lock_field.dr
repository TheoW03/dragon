"""Lock as an instance field - the silently-dropped acquire (2026-07-06).

If you have the code elow:

    from threading import Lock

    class Cache {
        def() {
            self._lock: Lock = Lock()
            self._d: dict[str, int] = {}
        }

        def put(k: str, v: int) -> None {
            with self._lock {          # or self._lock.acquire()/release()
                self._d[k] = v
            }
        }
    }

Lock is supposed to be a compiler intrinsic, not a Dragon class, and its
method/with dispatch only recognises a plan name receiver locak.acquire.
A Lock stored in an instance FIELD fell through to the generic path which bound
the value and emitted nada/nyet/nothing for acquire or release, this means the
compiled put() contained no locking at all. Single threaded code behaved similarly i.e.
no-op lock returns the right values, so nothing looked wrong until 2 vthread on different
os workers entered put(0 at once and the dict corrupted - or, after the current mutation
dectector landed, aborted wth dragon fatal: concurrent mutation of a shared dict even
though the code took the lcok

BEFORE: `with self._lock { ... }` and `self._lock.acquire()` compiled to
zero lock calls; two fired workers collided inside the dict.
AFTER: the ctor scan tags Lock-typed fields (classFieldClassName ->
"__Lock") and both the method dispatch and the with-lowering accept
attribute receivers, so field locks reach dragon_lock_acquire/release.

This suite runs 2 OS-parallel vthreads hammering one shared object; the
exact final count is only reachable if the field lock really serializes
(and it doubles as a detector no-false-positive check: an unlocked overlap
would abort the whole file).

One line: a Lock field now locks; before, it silently did not.
"""

from unittest import TestCase, main
from threading import Lock


class WithBox {
    def() {
        self._lock: Lock = Lock()
        self._d: dict[str, int] = {}
    }

    def put(k: str, v: int) -> None {
        with self._lock {
            self._d[k] = v
        }
    }

    def size() -> int {
        with self._lock {
            return len(self._d)
        }
    }
}


class AcquireBox {
    def() {
        self._lock: Lock = Lock()
        self._d: dict[str, int] = {}
    }

    def put(k: str, v: int) -> None {
        self._lock.acquire()
        self._d[k] = v
        self._lock.release()
    }

    def size() -> int {
        self._lock.acquire()
        const n: int = len(self._d)
        self._lock.release()
        return n
    }
}


const WB: WithBox = WithBox()
const AB: AcquireBox = AcquireBox()


def with_worker(prefix: str) -> None {
    i: int = 0
    while i < 5000 {
        WB.put(prefix + str(i), i)
        i = i + 1
    }
}


def acquire_worker(prefix: str) -> None {
    i: int = 0
    while i < 5000 {
        AB.put(prefix + str(i), i)
        i = i + 1
    }
}


class LockFieldTests(TestCase) {
    def test_with_field_lock_serializes_parallel_mutation() {
        t1: Task = fire with_worker("a")
        t2: Task = fire with_worker("b")
        t1.join()
        t2.join()
        # 2 workers x 5000 unique keys: exact only if the lock really locks
        # (an unlocked overlap corrupts the dict or trips the detector).
        self.assertEqual(WB.size(), 10000)
    }

    def test_explicit_field_acquire_release_serializes() {
        t1: Task = fire acquire_worker("a")
        t2: Task = fire acquire_worker("b")
        t1.join()
        t2.join()
        self.assertEqual(AB.size(), 10000)
    }
}


main([LockFieldTests()])
