"""Typed reads (spec section 20): all[T] / one[T] / val[T] over template[OQL].

Row classes hydrate themselves: the class constructor takes the matched
Document and pulls fields by subscript. The verbs accept only template[OQL]
values, so typed rows always ride the injection-safe parameter path; runtime
strings stay on the untyped find(). one[T] demands exactly one match
(NoRows / MultipleRows otherwise); val[T] additionally demands exactly one
projected field and returns the scalar
"""

from unittest import TestCase, main
from odb import ODB, Documents, Document, OQL, NoRows, MultipleRows
from odb.vfs import SimVFS
from odb.pager import create, Pager
from odb.errors import PrepareError


def _schema() -> dict[str, Any] {
    props: dict[str, Any] = {}
    props["id"] = {"type": "integer"}
    props["name"] = {"type": "string"}
    props["age"] = {"type": "integer"}
    req: list[Any] = ["id", "name", "age"]
    s: dict[str, Any] = {}
    s["type"] = "object"
    s["properties"] = props
    s["required"] = req
    return s
}


def _row(idv: int, nm: str, ag: int) -> dict[str, Any] {
    d: dict[str, Any] = {}
    d["id"] = idv
    d["name"] = nm
    d["age"] = ag
    return d
}


def _db() -> ODB {
    sim: SimVFS = SimVFS()
    p: Pager = create(sim, 4096)
    db: ODB = ODB(sim, p)
    c: Documents = db.schema("customers", _schema())
    c.save(_row(1, "Ada", 30))
    c.save(_row(2, "Bee", 16))
    c.save(_row(3, "Cy", 40))
    return db
}


class Customer {
    id: int
    name: str
    age: int

    def(d: Document) {
        self.id = d["id"]
        self.name = d["name"]
        self.age = d["age"]
    }
}


class TypedReadTest(TestCase) {
    def test_all_hydrates_rows() -> None {
        db: ODB = _db()
        min_age: int = 17
        rows: list[Customer] = db.all[Customer](template[OQL] { customers ? age > !{min_age} })
        self.assertEqual(len(rows), 2)
        self.assertEqual(rows[0].name, "Ada")
        self.assertEqual(rows[0].age, 30)
        self.assertEqual(rows[1].name, "Cy")
    }

    def test_all_empty_is_empty_list() -> None {
        db: ODB = _db()
        rows: list[Customer] = db.all[Customer](template[OQL] { customers ? age > 100 })
        self.assertEqual(len(rows), 0)
    }

    def test_one_returns_the_row() -> None {
        db: ODB = _db()
        who: str = "Bee"
        c: Customer = db.one[Customer](template[OQL] { customers ? name == !{who} })
        self.assertEqual(c.id, 2)
        self.assertEqual(c.age, 16)
    }

    def test_one_raises_norows() -> None {
        db: ODB = _db()
        raised: bool = False
        try {
            c: Customer = db.one[Customer](template[OQL] { customers ? id == 99 })
        } except NoRows {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_one_raises_multiplerows() -> None {
        db: ODB = _db()
        raised: bool = False
        try {
            c: Customer = db.one[Customer](template[OQL] { customers ? age > 1 })
        } except MultipleRows {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_val_int_scalar() -> None {
        db: ODB = _db()
        uid: int = 1
        age: int = db.val[int](template[OQL] { customers ? id == !{uid} { age } })
        self.assertEqual(age, 30)
    }

    def test_val_str_scalar() -> None {
        db: ODB = _db()
        uid: int = 3
        nm: str = db.val[str](template[OQL] { customers ? id == !{uid} { name } })
        self.assertEqual(nm, "Cy")
    }

    def test_val_requires_single_field_projection() -> None {
        db: ODB = _db()
        raised: bool = False
        try {
            x: int = db.val[int](template[OQL] { customers ? id == 1 { name, age } })
        } except PrepareError {
            raised = True
        }
        self.assertTrue(raised)
        raised = False
        try {
            y: int = db.val[int](template[OQL] { customers ? id == 1 })
        } except PrepareError {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_val_norows_and_multiple() -> None {
        db: ODB = _db()
        raised: bool = False
        try {
            x: int = db.val[int](template[OQL] { customers ? id == 99 { age } })
        } except NoRows {
            raised = True
        }
        self.assertTrue(raised)
        raised = False
        try {
            y: int = db.val[int](template[OQL] { customers ? age > 1 { age } })
        } except MultipleRows {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_injection_stays_data_through_typed_path() -> None {
        db: ODB = _db()
        evil: str = "Ada\" | 1 == 1"
        rows: list[Customer] = db.all[Customer](template[OQL] { customers ? name == !{evil} })
        self.assertEqual(len(rows), 0)
    }

    def test_run_template_write() -> None {
        db: ODB = _db()
        nm: str = "Dee"
        n: int = db.run(template[OQL] { add customers { id: 4, name: !{nm}, age: 22 } })
        self.assertEqual(n, 1)
        c: Customer = db.one[Customer](template[OQL] { customers ? id == 4 })
        self.assertEqual(c.name, "Dee")
    }

    def test_run_template_set_with_param() -> None {
        db: ODB = _db()
        newage: int = 31
        m: int = db.run(template[OQL] { set customers ? id == 1 { age: !{newage} } })
        self.assertEqual(m, 1)
        got: int = db.val[int](template[OQL] { customers ? id == 1 { age } })
        self.assertEqual(got, 31)
    }

    def test_run_template_injection_is_data() -> None {
        # An injection payload through a write param stays a value: it should only
        # change the field it targets, never inject a secnod statement.
        db: ODB = _db()
        evil: str = "z\" } add customers { id: 99, name: \"h\", age: 1"
        db.run(template[OQL] { set customers ? id == 1 { name: !{evil} } })
        # no id 99 was created; only three seeded customers remain.
        all_rows: list[Customer] = db.all[Customer](template[OQL] { customers ? id > 0 })
        self.assertEqual(len(all_rows), 3)
    }
}


main([TypedReadTest()])
