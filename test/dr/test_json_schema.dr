"""json.Schema - THE JSON Schema validation entry point.

One class, one flow: an instance names its dialect and owns a registry;
registration compiles a schema into the instance immediately; validation
runs by name. Registered schemas reference each other with
{"$ref": "<registered-name>"} through the instance's registry.

    s: Schema = Schema("draft-07")
    s.register("order", {"type": "object", "required": ["id"]})
    const r: ValidationResult = s.validate("order", json.loads(body))
"""

from unittest import TestCase, main
import json
from json import Schema, ValidationResult, ValidationError


class TestEntryPoint(TestCase) {
    def test_register_and_validate() -> None {
        s: Schema = Schema("draft-07")
        s.register("order", {"type": "object", "required": ["order"], "properties": {"order": {"type": "integer", "minimum": 1}}})
        self.assertEqual(s.validate("order", json.loads('{"order": 7}')).ok, True)
        const r: ValidationResult = s.validate("order", json.loads('{"order": 0}'))
        self.assertEqual(r.ok, False)
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$.order")
        self.assertEqual(r.errors[0].message, "value below minimum")
    }

    def test_register_parsed_text() -> None {
        # schemas arriving as text (an HTTP body, a DB column) parse then register
        s: Schema = Schema("draft-07")
        s.register("evt", json.loads_obj('{"type": "object", "required": ["id"]}'))
        self.assertEqual(s.validate("evt", json.loads('{"id": 1}')).ok, True)
        const r: ValidationResult = s.validate("evt", json.loads('{}'))
        self.assertEqual(r.errors[0].path, "$.id")
        self.assertEqual(r.errors[0].message, "required property missing")
    }

    def test_unknown_dialect_raises() -> None {
        caught: bool = False
        try {
            s: Schema = Schema("draft-99")
            s.register("x", {"type": "object"})
        } except {
            caught = True
        }
        self.assertEqual(caught, True)
    }

    def test_accepted_dialects() -> None {
        a: Schema = Schema("draft-07")
        b: Schema = Schema("2020-12")
        c: Schema = Schema("latest")
        a.register("t", {"type": "integer"})
        b.register("t", {"type": "integer"})
        c.register("t", {"type": "integer"})
        self.assertEqual(a.validate("t", json.loads("3")).ok, True)
        self.assertEqual(b.validate("t", json.loads("3")).ok, True)
        self.assertEqual(c.validate("t", json.loads("3")).ok, True)
    }
}


class TestRefs(TestCase) {
    def test_cross_schema_ref() -> None {
        s: Schema = Schema("draft-07")
        s.register("address", {"type": "object", "required": ["city"], "properties": {"city": {"type": "string", "minLength": 1}}})
        s.register("person", {"type": "object", "required": ["name", "home"], "properties": {"name": {"type": "string"}, "home": {"$ref": "address"}}})
        const good: Any = json.loads('{"name": "ada", "home": {"city": "lagos"}}')
        self.assertEqual(s.validate("person", good).ok, True)
        const bad: Any = json.loads('{"name": "ada", "home": {"city": ""}}')
        const r: ValidationResult = s.validate("person", bad)
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$.home.city")
        self.assertEqual(r.errors[0].message, "string shorter than minLength 1")
    }

    def test_ref_registered_later_resolves() -> None {
        # refs resolve at validation time through the registry, so a schema
        # may reference one registered after it
        s: Schema = Schema("draft-07")
        s.register("person", {"type": "object", "properties": {"home": {"$ref": "address"}}})
        s.register("address", {"type": "object", "required": ["city"]})
        const r: ValidationResult = s.validate("person", json.loads('{"home": {}}'))
        self.assertEqual(r.errors[0].path, "$.home.city")
    }

    def test_ref_in_items() -> None {
        s: Schema = Schema("draft-07")
        s.register("tag", {"type": "string", "minLength": 1})
        s.register("post", {"type": "object", "properties": {"tags": {"type": "array", "items": {"$ref": "tag"}}}})
        self.assertEqual(s.validate("post", json.loads('{"tags": ["a", "b"]}')).ok, True)
        const r: ValidationResult = s.validate("post", json.loads('{"tags": ["a", 2]}'))
        self.assertEqual(r.errors[0].path, "$.tags[1]")
        self.assertEqual(r.errors[0].message, "expected string, got integer")
    }

    def test_unknown_ref_reports() -> None {
        s: Schema = Schema("draft-07")
        s.register("person", {"type": "object", "properties": {"home": {"$ref": "address"}}})
        const r: ValidationResult = s.validate("person", json.loads('{"home": {}}'))
        self.assertEqual(r.ok, False)
        self.assertEqual(r.errors[0].path, "$.home")
        self.assertEqual(r.errors[0].message, "unknown $ref 'address'")
    }

    def test_circular_ref_reports_not_overflows() -> None {
        s: Schema = Schema("draft-07")
        s.register("a", {"$ref": "b"})
        s.register("b", {"$ref": "a"})
        const r: ValidationResult = s.validate("a", json.loads("1"))
        self.assertEqual(r.ok, False)
        self.assertEqual(len(r.errors), 1)
    }

    def test_recursive_schema_on_finite_value() -> None {
        # a self-referencing schema is fine when each hop consumes value
        # structure - a tree validates its own children
        s: Schema = Schema("draft-07")
        s.register("node", {"type": "object", "required": ["v"], "properties": {"v": {"type": "integer"}, "kids": {"type": "array", "items": {"$ref": "node"}}}})
        const tree: Any = json.loads('{"v": 1, "kids": [{"v": 2, "kids": []}, {"v": 3, "kids": [{"v": 4, "kids": []}]}]}')
        self.assertEqual(s.validate("node", tree).ok, True)
        const bad: Any = json.loads('{"v": 1, "kids": [{"v": "x", "kids": []}]}')
        const r: ValidationResult = s.validate("node", bad)
        self.assertEqual(r.errors[0].path, "$.kids[0].v")
    }
}


class TestKeywords(TestCase) {
    def test_type_names_and_unions() -> None {
        s: Schema = Schema("draft-07")
        s.register("obj", {"type": "object"})
        s.register("maybe", {"type": ["string", "null"]})
        s.register("num", {"type": "number"})
        s.register("int", {"type": "integer"})
        self.assertEqual(s.validate("obj", json.loads('{"a": 1}')).ok, True)
        self.assertEqual(s.validate("obj", json.loads('[1]')).ok, False)
        self.assertEqual(s.validate("maybe", json.loads('"x"')).ok, True)
        self.assertEqual(s.validate("maybe", json.loads('null')).ok, True)
        self.assertEqual(s.validate("maybe", json.loads('7')).ok, False)
        self.assertEqual(s.validate("num", json.loads('3')).ok, True)
        self.assertEqual(s.validate("int", json.loads('3.5')).ok, False)
        self.assertEqual(s.validate("int", json.loads('true')).ok, False)
    }

    def test_scalar_bounds_and_enum() -> None {
        s: Schema = Schema("draft-07")
        s.register("name", {"type": "string", "minLength": 2, "maxLength": 4})
        s.register("qty", {"minimum": 1.5, "maximum": 10})
        s.register("color", {"enum": ["red", "green", 3, true, None]})
        self.assertEqual(s.validate("name", json.loads('"a"')).ok, False)
        self.assertEqual(s.validate("name", json.loads('"ab"')).ok, True)
        self.assertEqual(s.validate("name", json.loads('"abcde"')).ok, False)
        self.assertEqual(s.validate("qty", json.loads('1')).ok, False)
        self.assertEqual(s.validate("qty", json.loads('2')).ok, True)
        self.assertEqual(s.validate("qty", json.loads('10.5')).ok, False)
        self.assertEqual(s.validate("color", json.loads('"green"')).ok, True)
        self.assertEqual(s.validate("color", json.loads('3')).ok, True)
        self.assertEqual(s.validate("color", json.loads('3.0')).ok, False)
        self.assertEqual(s.validate("color", json.loads('false')).ok, False)
        self.assertEqual(s.validate("color", json.loads('null')).ok, True)
    }

    def test_enum_deep_values() -> None {
        s: Schema = Schema("draft-07")
        s.register("pick", {"enum": [[1, 2], {"a": 1}]})
        self.assertEqual(s.validate("pick", json.loads('[1, 2]')).ok, True)
        self.assertEqual(s.validate("pick", json.loads('{"a": 1}')).ok, True)
        self.assertEqual(s.validate("pick", json.loads('[1, 3]')).ok, False)
        self.assertEqual(s.validate("pick", json.loads('{"a": 2}')).ok, False)
    }

    def test_arrays_and_multi_error_report() -> None {
        s: Schema = Schema("draft-07")
        s.register("ints", {"type": "array", "items": {"type": "integer"}, "minItems": 1, "maxItems": 3})
        self.assertEqual(s.validate("ints", json.loads('[]')).ok, False)
        self.assertEqual(s.validate("ints", json.loads('[1, 2]')).ok, True)
        self.assertEqual(s.validate("ints", json.loads('[1, 2, 3, 4]')).ok, False)
        const r: ValidationResult = s.validate("ints", json.loads('[1, "x", 3.5]'))
        self.assertEqual(len(r.errors), 2)
        self.assertEqual(r.errors[0].path, "$[1]")
        self.assertEqual(r.errors[0].message, "expected integer, got string")
        self.assertEqual(r.errors[1].path, "$[2]")
        self.assertEqual(r.errors[1].message, "expected integer, got number")
    }
}


class TestPayloadRepresentations(TestCase) {
    def test_dict_literal_payload() -> None {
        # payloads are Any: a Dragon dict literal (bare identifier keys)
        # validates without any JSON text round-trip
        s: Schema = Schema("draft-07")
        s.register("order", {type: "object", required: ["order"], properties: {order: {type: "integer", minimum: 1}}})
        self.assertEqual(s.validate("order", {order: 7}).ok, True)
        self.assertEqual(s.validate("order", {order: 0}).ok, False)
    }

    def test_native_list_payload() -> None {
        # a monomorphized Dragon list validates identically to a parsed box
        # list - the walker sizes and iterates through the Any value, which
        # dispatches on the payload header
        s: Schema = Schema("draft-07")
        s.register("tags", {type: "array", items: {type: "string", minLength: 1}, minItems: 1})
        self.assertEqual(s.validate("tags", ["a", "b"]).ok, True)
        names: list[str] = ["x", ""]
        const r: ValidationResult = s.validate("tags", names)
        self.assertEqual(r.ok, False)
        self.assertEqual(r.errors[0].path, "$[1]")
        self.assertEqual(r.errors[0].message, "string shorter than minLength 1")
        nums: list[int] = [1, 2]
        const r2: ValidationResult = s.validate("tags", nums)
        self.assertEqual(r2.errors[0].path, "$[0]")
        self.assertEqual(r2.errors[0].message, "expected string, got integer")
        empty: list[str] = []
        self.assertEqual(s.validate("tags", empty).ok, False)
    }

    def test_native_scalar_payload() -> None {
        s: Schema = Schema("draft-07")
        s.register("color", {enum: ["red", "green"]})
        self.assertEqual(s.validate("color", "green").ok, True)
        self.assertEqual(s.validate("color", "blue").ok, False)
        s.register("qty", {type: "integer", minimum: 1})
        self.assertEqual(s.validate("qty", 3).ok, True)
        self.assertEqual(s.validate("qty", 0).ok, False)
    }
}


class TestPartialRequired(TestCase) {
    # Regression: a `required` list with >=2 entries where SOME are present
    # and some missing. The validator iterates the required list through Any
    # (box-iteration) with `const name: str = r` in the body. A codegen bug
    # mis-classified that str local as a class instance (a stale program-wide
    # varClassNames entry for the loop-var name bled through resolveExprClassName
    # on the Union loop var), decref'ing the string with the generic
    # dragon_decref at scope exit - heap corruption / a garbled error path
    # ($.nrder instead of $.items). The explicit `str` annotation must win.
    def test_first_present_second_missing() -> None {
        s: Schema = Schema("draft-07")
        s.register("order", {type: "object", required: ["order", "items"]})
        const r: ValidationResult = s.validate("order", {order: 7})
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$.items")
        self.assertEqual(r.errors[0].message, "required property missing")
    }

    def test_multiline_nested_schema() -> None {
        s: Schema = Schema("draft-07")
        s.register("item", {
            type: "object",
            required: ["sku"],
            properties: {sku: {type: "string", minLength: 1}}
        })
        s.register("order", {
            type: "object",
            required: ["order", "items"],
            properties: {
                order: {type: "integer", minimum: 1},
                items: {type: "array", minItems: 1, items: {"$ref": "item"}}
            }
        })
        self.assertEqual(s.validate("order", {order: 7, items: [{sku: "tea"}]}).ok, True)
        const r: ValidationResult = s.validate("order", {order: 7, items: [{sku: ""}]})
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$.items[0].sku")
    }
}


class TestRealWorldShape(TestCase) {
    def test_amebo_order_schema() -> None {
        s: Schema = Schema("draft-07")
        s.register("item", {"type": "object", "required": ["sku", "qty"], "properties": {"sku": {"type": "string"}, "qty": {"type": "integer", "minimum": 1}}})
        s.register("order.placed", {"type": "object", "required": ["order", "items"], "properties": {"order": {"type": "string", "minLength": 1}, "items": {"type": "array", "minItems": 1, "items": {"$ref": "item"}}}})
        self.assertEqual(s.validate("order.placed", json.loads('{"order": "ord-9", "items": [{"sku": "tea", "qty": 2}]}')).ok, True)

        const r: ValidationResult = s.validate("order.placed", json.loads('{"order": "", "items": [{"sku": "tea", "qty": 0}, {"sku": 5}]}'))
        self.assertEqual(len(r.errors), 4)
        self.assertEqual(r.errors[0].path, "$.order")
        self.assertEqual(r.errors[0].message, "string shorter than minLength 1")
        self.assertEqual(r.errors[1].path, "$.items[0].qty")
        self.assertEqual(r.errors[1].message, "value below minimum")
        self.assertEqual(r.errors[2].path, "$.items[1].qty")
        self.assertEqual(r.errors[2].message, "required property missing")
        self.assertEqual(r.errors[3].path, "$.items[1].sku")
        self.assertEqual(r.errors[3].message, "expected string, got integer")
    }
}


main([TestEntryPoint(), TestRefs(), TestKeywords(), TestPayloadRepresentations(), TestPartialRequired(), TestRealWorldShape()])
