"""
Given the code below:

    def run() -> None {
        p: Any = Dog("rex")
        print("hi")
    }                          # SIGSEGV here (before the fix)

An `Any` local is 16-byte {tag, payload} box slot. Binding a class
instance to it is ordinary code, but the class-name tracking that powers
member dispatch also overrdes the slot's cleanup kind from Union to
ClassInstance. Scope cleanup then treats the box slot as a plain pointer
slot: it loads the FIRST 8 bytes - the tag word (7) - and calls dragon_decref(7),
dereferencing the integer as a heap header
(AddressSanitizer: SEGV on address 0x7). Every function that ever parked
an instance in an `Any` local crashed at return.

WHY the unwind path never crashed: exception cleanup registered the
extracted payload with its tag; only the NORMAL scope-exit decref read the
slot with the wrong shape.

BEFORE: the snippet above SEGV'd at scope exit. AFTER: the kind override
skips box slots (the slot stays Union, so cleanup extracts tag + payload),
and the cleanup emitter treats the slot's LLVM type as ground truth - a
16-byte box slot takes the tag-dispatched decref no matter what the kind
map drifted to. The instance is decref'd properly (LSan-verified: freed,
not leaked).

One line: an Any-boxed instance now dies by its tag, not as its tag
"""

from unittest import TestCase, main


class Dog {
    def(name: str) {
        self.name = name
    }

    def get_name() -> str {
        return self.name
    }
}


def park_and_return(n: int) -> int {
    p: Any = Dog("rex" + str(n))
    return n * 2
}


class BoxedInstanceScopeTests(TestCase) {
    def test_boxed_instance_scope_exit_no_crash() {
        # Before the fix the FIRST call SEGV'd at scope exit
        self.assertEqual(park_and_return(1), 2)
        i: int = 0
        while i < 500 {
            self.assertEqual(park_and_return(i), i * 2)
            i = i + 1
        }
    }

    def test_boxed_instance_narrowed_use_then_exit() {
        p: Any = Dog("odo")
        if isinstance(p, Dog) {
            self.assertEqual(p.get_name(), "odo")
        }
        # p leaves this method's scope boxed - cleanup must tag-dispatch
        self.assertTrue(True)
    }
}


main([BoxedInstanceScopeTests()])
